# ─────────────────────────────────────────────
# WorkNomads — environment variable template
# Copy to .env and fill in real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────
POSTGRES_USER=worknomads
POSTGRES_PASSWORD=changeme
POSTGRES_DB=worknomads
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Constructed DSN (used by services)
DATABASE_URL=postgresql+asyncpg://worknomads:changeme@postgres:5432/worknomads

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── RabbitMQ ──────────────────────────────────
RABBITMQ_USER=worknomads
RABBITMQ_PASSWORD=changeme
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_URL=amqp://worknomads:changeme@rabbitmq:5672/

# ── MinIO / S3 ────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=worknomads-photos
MINIO_SECURE=false
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_BUCKET_PUBLIC=true

# ── JWT ───────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Service URLs (used by api-gateway) ────────
AUTH_SERVICE_URL=http://auth-service:8001
SUBMISSION_SERVICE_URL=http://submission-service:8002
CLASSIFIER_SERVICE_URL=http://classifier-service:8003
ADMIN_SERVICE_URL=http://admin-service:8004

# ── Application ───────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
ALLOWED_ORIGINS=http://localhost,http://localhost:3000
